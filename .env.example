# ─────────────────────────────────────────────────────────────────────────
# Python backend env. The frontend's `.env` should NOT duplicate any of
# these — the only frontend-side variable that mentions this service is
# `BACKEND_URL`, which points at it.
# ─────────────────────────────────────────────────────────────────────────

# ─── Database (Supabase Postgres) ────────────────────────────────────────
# Use the asyncpg driver scheme — postgresql+asyncpg://...
# Get the password from Supabase → Project Settings → Database → Connection
# string → "URI" tab. Use the pooler URL (...pooler.supabase.com:5432).
DATABASE_URL=postgresql+asyncpg://postgres:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Synchronous URL used by Alembic + seeders. Same DB, different driver
# (psycopg2). If you don't set it explicitly, the app derives it from
# DATABASE_URL by swapping +asyncpg → +psycopg2.
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# ─── Auth (JWT) ──────────────────────────────────────────────────────────
# 32+ byte random string. Use:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-32-byte-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=720

# ─── Module Entitlement & Licensing ─────────────────────────────────────
# The app fails CLOSED with no licence (every module locks). Provide ONE of:
#   • LICENCE_TOKEN — the full signed token. Best for cloud/container deploys
#     (Vercel/Dokploy) whose filesystem is ephemeral. Get it from a .lic file:
#     `cat clients/<customer>.lic`. The token is signed, not secret — safe to
#     put in env. This is the recommended way to license a hosted deployment.
#   • LICENCE_FILE_PATH — path to a .lic file (default: <backend>/licence.lic).
#     Best for on-prem where you drop the file on disk / a mounted volume.
# A file, when present, takes precedence over LICENCE_TOKEN.
# LICENCE_TOKEN=
# LICENCE_FILE_PATH=
# LICENCE_WARN_DAYS=14

# ─── Supabase Storage ────────────────────────────────────────────────────
# Required for incident attachments. Service-role key — NEVER expose to the
# browser. The frontend talks to the backend, the backend talks to Supabase.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_INCIDENT_BUCKET=incident-attachments

# ─── CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins. Add your Vercel URL when
# deploying to production. The Next.js BFF and the browser BOTH need to be
# allowed when fetching from the backend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── AI Agents (Anthropic) ──────────────────────────────────────────────
# Used by:
#   • TriageAgent — runs on observation submission, suggests
#     severity / category / priority + first-response prompts.
#   • LessonsDistributionAgent — runs on observation closure, generates a
#     sharable lesson + target audience + follow-up actions.
# Optional — when ANTHROPIC_API_KEY is unset the agents log + skip; the
# workflow itself keeps working.
ANTHROPIC_API_KEY=
# Default to Haiku for cost; override per-agent in code if you need
# Sonnet/Opus quality. https://docs.claude.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Notifications — Email (SMTP / nodemailer-compatible) ─────────────
# Used by the auto-promotion service (Critical Near Miss → Incident
# alert) and future workflow escalation cron. Optional — when unset,
# notifications log + no-op; the workflow itself keeps working.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=
EMAIL_FROM=SafeOps360 Alerts <alerts@example.com>

# ─── Notifications — SMS (MSG91 default, Twilio fallback) ─────────────
# MSG91 is cheap + India DLT-compliant (₹0.15-0.25 per SMS). Set
# MSG91_AUTH_KEY (and MSG91_TEMPLATE_ID for DLT-registered flows) to
# enable. If both providers are configured, MSG91 is tried first.
MSG91_AUTH_KEY=
MSG91_SENDER=SAFEOP
MSG91_TEMPLATE_ID=
# Twilio fallback — leave blank if not using
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── Server ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
